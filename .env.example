# Credentials for the paper/dataset downloaders (scripts/).
#
# These already exist in ../winterchill/.env — the easiest path is to NOT copy
# secrets here and instead run:   python scripts/fetch_pdfs.py --env ../winterchill/.env
# This template documents what the scripts look for.

# --- BrightData Web Unlocker (downloads paywalled/blocked PDFs) ---
# NOTE: the proxy requires the runner's egress IP to be whitelisted in the zone
# (Allowed IPs). API mode (token) does not need the IP whitelist.
BRIGHTDATA_API_KEY=
BRIGHTDATA_WU_ZONE=web_unlocker1
BRIGHTDATA_WU_USERNAME=brd-customer-<id>-zone-web_unlocker1
BRIGHTDATA_WU_PASSWORD=
BRIGHTDATA_WU_HOST=brd.superproxy.io
BRIGHTDATA_WU_PORT=33335

# --- OpenRouter (Perplexity models for discovering PDF links) ---
OPENROUTER_API_KEY=

# --- Unpaywall (open-access resolution) requires a contact email, not a key ---
UNPAYWALL_EMAIL=you@example.com
